name: "⚙️ Use Case"
description: "Describe a specific use case that supports a user requirement"
title: "Use Case: [short title]"
labels: ["use-case"]
body:
  - type: markdown
    attributes:
      value: |
        ## ⚙️ Use Case  
        Use this template to describe a single user interaction or system process.
  - type: input
    id: linked_requirement
    attributes:
      label: "Linked Requirement"
      description: "Reference the related user requirement (issue number)."
      placeholder: "#101"
  - type: textarea
    id: scenario
    attributes:
      label: "Scenario Description"
      description: "Describe the purpose and context of this use case."
      placeholder: "The manager creates a new daily special to promote lunch items."
  - type: input
    id: actor
    attributes:
      label: "Primary Actor"
      placeholder: "Restaurant Manager"
  - type: input
    id: trigger
    attributes:
      label: "Trigger"
      placeholder: "Manager clicks 'Add Daily Special'"
  - type: textarea
    id: preconditions
    attributes:
      label: "Preconditions"
      placeholder: "Manager is logged in and has 'edit specials' permission."
  - type: textarea
    id: postconditions
    attributes:
      label: "Postconditions"
      placeholder: "Daily special appears in the customer app and expires after 24 hours."
  - type: textarea
    id: main_flow
    attributes:
      label: "Main Flow"
      value: |
        1. Actor does X  
        2. System responds Y  
        3. Actor continues Z
  - type: textarea
    id: alternate_flows
    attributes:
      label: "Alternate or Exception Flows"
      placeholder: "Describe any variations, errors, or exceptions."
  - type: textarea
    id: acceptance_criteria
    attributes:
      label: "Acceptance Criteria"
      value: |
        - [ ] The system performs [expected behavior]  
        - [ ] User receives [expected feedback/result]  
        - [ ] Validation and error handling are clear
  - type: dropdown
    id: priority
    attributes:
      label: "Priority"
      options:
        - High
        - Medium
        - Low
  - type: dropdown
    id: status
    attributes:
      label: "Status"
      options:
        - To Do
        - In Progress
        - Done
  - type: input
    id: owner
    attributes:
      label: "Owner"
      placeholder: "@username"
